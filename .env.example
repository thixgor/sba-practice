# ============================================
# SBA Practice System - Environment Variables
# ============================================

# MongoDB Atlas
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/sba-practice?retryWrites=true&w=majority

# JWT Secrets (generate with: openssl rand -hex 32)
JWT_SECRET=your-256-bit-secret-here
JWT_REFRESH_SECRET=your-different-256-bit-secret-here

# Field Encryption (generate with: openssl rand -hex 32)
FIELD_ENCRYPTION_KEY=your-32-byte-hex-key-here

# hCaptcha
HCAPTCHA_SECRET=your-hcaptcha-secret
NEXT_PUBLIC_HCAPTCHA_SITEKEY=your-hcaptcha-sitekey

# Vercel KV (Redis)
KV_URL=
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Vercel Blob (Image uploads)
BLOB_READ_WRITE_TOKEN=

# SMTP (Email)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@sbahq.org

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=SBA Practice System
